# ─── AI Waiter – Frontend Environment Variables ─────────────────────────────
# Copy this file to .env.local for local development.
# On Vercel: add these in Project → Settings → Environment Variables.

# ── Backend API URL ───────────────────────────────────────────────────────────
# Local dev → point to your locally running FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000
#
# Vercel monorepo deployment (vercel.json routes /api/* to the Python backend)
# → Leave this UNSET in Vercel env vars; the app will use relative URLs.
#
# Separate backend deployment (Railway / Render / etc.)
# → Set this to your backend's public URL, e.g.:
# NEXT_PUBLIC_API_URL=https://ai-waiter-api.up.railway.app

# ── Restaurant ID (multi-tenant support) ─────────────────────────────────────
NEXT_PUBLIC_RESTAURANT_ID=default
